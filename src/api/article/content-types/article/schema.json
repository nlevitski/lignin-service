{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "site": {
      "type": "enumeration",
      "required": true,
      "default": "lignin.by",
      "enum": [
        "lignin.by",
        "ligninsorbent.ru"
      ]
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "mission": {
      "type": "string"
    },
    "teaser": {
      "type": "blocks"
    },
    "summary": {
      "type": "string"
    },
    "content": {
      "type": "blocks"
    },
    "imgCaption": {
      "type": "string"
    },
    "path": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "titleSmall": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "coverPreview": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "metaDescription": {
      "type": "string"
    },
    "metaKeywords": {
      "type": "string"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": true
    },
    "contentMD": {
      "type": "richtext"
    }
  }
}
